# Binance API Credentials (get from https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072)
# Use Testnet first: https://testnet.binance.com/
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Set to "true" to use testnet (recommended for testing)
BINANCE_TESTNET=true

# Webhook server config
WEBHOOK_PORT=3001
WEBHOOK_AUTH_TOKEN=
