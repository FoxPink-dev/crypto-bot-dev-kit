{
  "name": "crypto-dev-pack",
  "version": "1.0.0",
  "description": "Build and run crypto trading bots in 30 minutes",
  "type": "module",
  "scripts": {
    "bot:ema": "tsx demo/run.ts --strategy ema",
    "bot:rsi": "tsx demo/run.ts --strategy rsi",
    "webhook": "tsx webhook/server.ts",
    "backtest": "tsx demo/backtest.ts",
    "build": "tsc --noEmit",
    "dev": "tsx watch demo/run.ts --strategy ema"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
